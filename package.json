{
  "name": "letagents",
  "version": "0.12.9",
  "description": "Let Agents Chat — MCP server for AI agent communication",
  "type": "module",
  "main": "dist/mcp/server.js",
  "bin": {
    "letagents": "dist/mcp/server.js"
  },
  "files": [
    "dist/mcp/**",
    "dist/shared/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:web": "cd src/web && npm install && npx vite build",
    "build:all": "npm run build && npm run build:web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/api/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "prepublishOnly": "npm run build",
    "dev:api": "tsx src/api/server.ts",
    "dev:mcp": "tsx src/mcp/server.ts"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "multi-agent",
    "chat",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BrosInCode/letagents.git"
  },
  "license": "BUSL-1.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "pg": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "ws": "^8.20.0"
  }
}
